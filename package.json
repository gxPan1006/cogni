{
  "name": "cogni",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "typecheck": "pnpm run build && pnpm -r typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "ci": "pnpm -r --filter './packages/*' build && pnpm -r typecheck && pnpm vitest run packages/cloud packages/contract --no-file-parallelism"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
