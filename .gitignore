node_modules/
dist/
# Bun-compiled runner-host single binary (~55MB) — generated, never committed
dist-bin/
build/
*.log
.DS_Store
.env
.env.*
!.env.example
# Vite build-time env (no secrets — just public cloud URL). Tracked so CI / fresh
# checkouts pick up production target without manual setup.
!apps/desktop/.env.production
!apps/web/.env.production
.worktrees/
# Ignore .claude/ local state, but track shared project slash-commands
.claude/*
!.claude/commands/
.superpowers/
*.tsbuildinfo
# Per-commit work logs kept locally only (per ~/.claude/CLAUDE.md convention)
changelog/
# Playwright MCP screenshots / snapshots from local UI verification
.playwright-mcp/
.claude-supervisor/
