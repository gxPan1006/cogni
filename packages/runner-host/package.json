{
  "name": "@cogni/runner-host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "bin": { "cogni-runner-host": "./dist/main.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "install:launchd": "bash scripts/install-launchd.sh",
    "uninstall:launchd": "bash scripts/uninstall-launchd.sh"
  },
  "dependencies": {
    "@cogni/contract": "workspace:*",
    "@cogni/shared": "workspace:*",
    "execa": "^9.5.2",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14"
  }
}
