DATABASE_URL=postgres://...neon...
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-32-bytes-minimum-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PUBLIC_URL=http://localhost:8787
PORT=8787

# Email transport for magic-link login.
# - `console` (default): prints the link to stdout; copy-paste to log in. Use
#   for local dev / first-time setup. Never use in production.
# - `resend`: POSTs to api.resend.com. Required env: RESEND_API_KEY, EMAIL_FROM.
# - `smtp`:   classic SMTP via nodemailer. Required env: SMTP_HOST, SMTP_PORT,
#             SMTP_USER, SMTP_PASSWORD, EMAIL_FROM. Use when you already have
#             a mailbox at spacemail / postmark / aws-ses-smtp / etc.
EMAIL_TRANSPORT=console
RESEND_API_KEY=
# Required only when EMAIL_TRANSPORT=smtp.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# Optional; defaults from SMTP_PORT (465 → true, 587 → false). Set to override.
# SMTP_SECURE=true
# Optional SNI override. Set when SMTP_HOST is a tunnel endpoint (e.g.
# 127.0.0.1 via `ssh -L 1465:mail.your-provider.com:465 -N -f your-vps`) but
# the real server's TLS cert is for a different name. Without this, TLS fails
# with HOSTNAME_MISMATCH because nodemailer defaults SNI to SMTP_HOST.
# SMTP_TLS_SERVERNAME=mail.your-provider.com
# Sender; must be authorised by your transport (verified Resend domain, or the
# SMTP account's own mailbox).
EMAIL_FROM=Cogni <login@cogni.example>
# Magic-link expiry in minutes; 1-60 allowed; default 15.
MAGIC_LINK_TTL_MIN=15

# Web Push (PWA notifications: task done / needs-review / failed). Optional —
# omit all three and push is disabled (the /api/push routes 503, the app boots
# fine). Generate a keypair with:
#   pnpm --filter @cogni/cloud exec node -e "console.log(require('web-push').generateVAPIDKeys())"
# VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY must be set together.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI per the Web Push spec (mailto: or https:). Defaults to
# mailto:admin@ai-cognit.com.
# VAPID_SUBJECT=mailto:admin@ai-cognit.com
