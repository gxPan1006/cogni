{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "deep-link:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "cogni-runner-host", "sidecar": true }]
    }
  ]
}