{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cogni",
  "version": "0.2.19",
  "identifier": "com.cogni.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/menubarTemplate.png",
      "iconAsTemplate": true,
      "showMenuOnLeftClick": false,
      "tooltip": "Cogni"
    },
    "windows": [
      {
        "title": "Cogni",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["cogni"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/cogni-runner-host"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
